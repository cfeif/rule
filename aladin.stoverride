proxy-groups: #!replace
  # ┌─────────────────────────────────────────────────────┐
  # │  CONTROL GROUP — manual selection of country groups  │
  # └─────────────────────────────────────────────────────┘
  - name: Aladdin Network
    type: select
    proxies:
      - 🚀 Auto Select
      - 🔄 Fallback
      - 🇭🇰 香港
      - 🇸🇬 新加坡
      - 🇯🇵 日本
      - 🇺🇸 美国
      - 🇹🇼 台湾
      - 🇰🇷 韩国
      - 送中
      - DIRECT

  # ┌──────────────────────────────────────────────────────┐
  # │  AUTO & FALLBACK — latency-based automatic selection  │
  # └──────────────────────────────────────────────────────┘
  - name: 🚀 Auto Select
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '^(?!.*?(剩余|距离|套餐|免登)).*'

  - name: 🔄 Fallback
    type: fallback
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    filter: '^(?!.*?(剩余|距离|套餐|免登)).*'

  # ┌────────────────────────────────────────────────────────────────────┐
  # │  COUNTRY GROUPS — url-test (best node auto-selected), regex filter  │
  # └────────────────────────────────────────────────────────────────────┘
  - name: 🇭🇰 香港
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '香港'

  - name: 🇸🇬 新加坡
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '新加坡'

  - name: 🇯🇵 日本
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '日本'

  - name: 🇺🇸 美国
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '美国'

  - name: 🇹🇼 台湾
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '台湾'

  - name: 🇰🇷 韩国
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '韩国'

  # ┌──────────────────────────────────────────────────────────────────────┐
  # │  送中 — HK nodes 06–10 specifically, for YouTube & CN-friendly media  │
  # └──────────────────────────────────────────────────────────────────────┘
  - name: 送中
    type: url-test
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    tolerance: 50
    filter: '香港0[6-9]|香港10'

  # ┌──────────────────────────────────────────────────────┐
  # │  SERVICE GROUPS — select, default to Aladdin Network  │
  # └──────────────────────────────────────────────────────┘
  - name: Telegram
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇭🇰 香港, 🇸🇬 新加坡, 🇯🇵 日本, 🇺🇸 美国, 🇹🇼 台湾, 🇰🇷 韩国, DIRECT]

  - name: ChatGPT
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇹🇼 台湾, 🇰🇷 韩国, DIRECT]

  - name: Claude AI
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇹🇼 台湾, 🇰🇷 韩国, DIRECT]

  - name: Google Gemini
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇭🇰 香港, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇹🇼 台湾, DIRECT]

  # YouTube defaults to 送中 (HK06–10) — good for CN-licensed content & low latency
  - name: Google YouTube
    type: select
    proxies: [送中, Aladdin Network, 🚀 Auto Select, 🇭🇰 香港, 🇸🇬 新加坡, 🇯🇵 日本, 🇺🇸 美国, 🇹🇼 台湾, DIRECT]

  - name: Bili
    type: select
    proxies: [DIRECT, 🇭🇰 香港, 🇹🇼 台湾, Aladdin Network]

  - name: Bahamut
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇹🇼 台湾, 🇭🇰 香港, 🇸🇬 新加坡, DIRECT]

  - name: Github
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇭🇰 香港, DIRECT]

  - name: Crypto
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇸🇬 新加坡, 🇯🇵 日本, 🇭🇰 香港, DIRECT]

  - name: Discord
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇭🇰 香港, DIRECT]

  - name: Netflix
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇭🇰 香港, 🇹🇼 台湾, DIRECT]

  - name: Disney
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇭🇰 香港, 🇹🇼 台湾, DIRECT]

  - name: Pikpak
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇸🇬 新加坡, 🇭🇰 香港, DIRECT]

  - name: HBO
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇸🇬 新加坡, 🇭🇰 香港, DIRECT]

  - name: OtherMedia
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇭🇰 香港, DIRECT]

  - name: Paypal
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇸🇬 新加坡, DIRECT]

  - name: Twitter
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇭🇰 香港, DIRECT]

  - name: Apple
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇭🇰 香港, DIRECT]

  - name: WeChat
    type: select
    proxies: [DIRECT, 🇭🇰 香港, Aladdin Network]

  - name: Steam
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇯🇵 日本, 🇸🇬 新加坡, 🇭🇰 香港, DIRECT]

  - name: SteamCN
    type: select
    proxies: [DIRECT, 🇭🇰 香港, Aladdin Network]

  - name: Microsoft
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🇺🇸 美国, 🇭🇰 香港, 🇸🇬 新加坡, DIRECT]

  - name: Final
    type: select
    proxies: [Aladdin Network, 🚀 Auto Select, 🔄 Fallback, 🇭🇰 香港, 🇸🇬 新加坡, 🇯🇵 日本, 🇺🇸 美国, 🇹🇼 台湾, 🇰🇷 韩国, 送中, DIRECT]

rules: #!replace
  # ── Custom direct domains (local services, IoT, etc.) ──
  - 'DOMAIN,readapi.zziot.life,DIRECT'
  - 'DOMAIN-SUFFIX,s.outong-valve.com,DIRECT'
  - 'DOMAIN-SUFFIX,ectrip.com,DIRECT'

  # ── Custom direct IPs (CN cloud servers) ──
  - 'IP-CIDR,8.134.152.191/32,DIRECT,no-resolve'
  - 'IP-CIDR,8.134.107.77/32,DIRECT,no-resolve'
  - 'IP-CIDR,8.134.250.119/32,DIRECT,no-resolve'
  - 'IP-CIDR,132.232.133.234/32,DIRECT,no-resolve'
  - 'IP-CIDR,139.155.145.118/32,DIRECT,no-resolve'
  - 'IP-CIDR,8.138.251.121/32,DIRECT,no-resolve'
  - 'IP-CIDR,8.138.59.17/32,DIRECT,no-resolve'

  # ── Aladdin provider & related domains ──
  - 'DOMAIN-SUFFIX,dlandroid.rcv.sandai.net,Aladdin Network'
  - 'DOMAIN-SUFFIX,embylife.xyz,Aladdin Network'
  - 'DOMAIN-SUFFIX,emby.moe,Aladdin Network'
  - 'DOMAIN-SUFFIX,xxlb.net,Aladdin Network'
  - 'DOMAIN-SUFFIX,liminalnet.site,Aladdin Network'
  - 'DOMAIN-SUFFIX,kdcloud.uk,Aladdin Network'
  - 'DOMAIN-SUFFIX,koodog.com,Aladdin Network'
  - 'DOMAIN-SUFFIX,kindo.cc,Aladdin Network'
  - 'DOMAIN-SUFFIX,0085.top,Aladdin Network'
  - 'DOMAIN-SUFFIX,avatargpt.xyz,Aladdin Network'
